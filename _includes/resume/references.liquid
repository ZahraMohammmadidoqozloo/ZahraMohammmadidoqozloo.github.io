<div class="list-groups">
  {% for ref in data[1] %}
    <div class="list-group">
      <table class="table-cv list-group-table">
        <tbody>
          <tr>
            {% if ref.icon %}
              <td class="list-group-category-icon">
                <i class="{{ ref.icon }}"></i>
              </td>
            {% else %}
              <td class="list-group-category-icon"></td>
            {% endif %}
            <td class="list-group-category">
              {% if ref.url %}
                <a href="{{ ref.url }}" target="_blank">{{ ref.name }}</a>
              {% else %}
                {{ ref.name }}
              {% endif %}
            </td>
          </tr>
          <tr>
            <td></td>
            <td class="list-group-name">
              {{ ref.reference }}
              {% if ref.email %}
                <br><a href="mailto:{{ ref.email }}">{{ ref.email }}</a>
              {% endif %}
            </td>
          </tr>
        </tbody>
      </table>
    </div>
  {% endfor %}
</div>
</style>
